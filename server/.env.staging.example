# DailyForge — local dev pointed at Neon `staging` branch.
#
# Copy this file to `.env` and fill in the placeholders. The defaults below
# assume you want local dev (`npm run dev`, smoke harnesses, seed scripts)
# to read/write the staging Neon branch — which is the safe default after
# S15-T1.
#
# To run a mutating script against PRODUCTION instead, you must set BOTH
# of the following on the invocation:
#     NODE_ENV=production ALLOW_PROD_MUTATION=true node scripts/<name>.js
# Either alone is rejected by server/scripts/lib/prod-guard.mjs. This is
# deliberately a two-variable override so a single typo cannot rewrite
# production data.

PORT=3001

# Staging Neon connection string. Grab from Neon console → Branches → staging →
# Connection details (use the pooled URL for app workloads).
DATABASE_URL=postgresql://<user>:<password>@<staging-host>.neon.tech/neondb?sslmode=require&channel_binding=require

NODE_ENV=staging

# OK to reuse the dev JWT secret for staging.
# Production MUST use a different value — never reuse this.
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_IN=7d

CLIENT_URL=http://localhost:5173

# ImageKit (Media CDN) — S15-T7 will revisit whether prod and staging should
# point at different ImageKit accounts. For now staging shares the dev keys.
IMAGEKIT_PUBLIC_KEY=your_public_key
IMAGEKIT_PRIVATE_KEY=your_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id

# ExerciseDB (RapidAPI) — optional, free-exercise-db used as fallback.
RAPIDAPI_KEY=your_rapidapi_key
